VITE_API_URL=https://api.craftad.ai
VITE_APP_NAME=CraftAd
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- DEV BYPASS (REMOVE BEFORE PROD) ---
# Set to true to show a "skip trial verification" button on /trial.
# The backend's TRANZILA_BYPASS_ENABLED gates the actual endpoint —
# both flags must be true for the bypass to fire.
VITE_TRANZILA_BYPASS_ENABLED=false

# --- PAYMENT TEST MODE (REMOVE BEFORE PROD) ---
# Set to true to display ₪1 prices on the pricing page + show a
# TEST MODE banner. Pair with backend BILLING_TEST_MODE (which is the
# authoritative gate — it overrides the actual charged amount). Both
# flags should be set together so what the user sees matches what
# they're actually charged.
VITE_BILLING_TEST_MODE=false
